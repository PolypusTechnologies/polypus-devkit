  { name:'yfinance', desc:'Download Yahoo Finance data. Historical prices, fundamentals, options, news for free.', use:'ATLAS backtesting data, market research, competitor financial analysis' },
  { name:'ccxt', desc:'Crypto trading library. Connect to 100+ exchanges with one unified API.', use:'ATLAS crypto trading on BTC, crypto exchange integration, CEX/DEX data' },
  { name:'pandas-ta', desc:'Technical analysis library for pandas. 130+ indicators — RSI, MACD, Bollinger, EMA.', use:'ATLAS strategy indicators, signal generation, trend analysis' },
  { name:'backtesting', desc:'Backtesting framework. Test strategies on historical data. Fast, Pythonic, Plotly charts.', use:'ATLAS strategy validation before live trading' },
  { name:'backtrader', desc:'Full-featured backtesting platform. Multiple data feeds, broker simulation, analyzers.', use:'ATLAS comprehensive strategy backtesting, walk-forward optimization' },
  { name:'quantstats', desc:'Portfolio performance analysis. Sharpe, drawdown, tearsheet, benchmarking, HTML reports.', use:'ATLAS performance reporting, prop firm challenge prep, strategy evaluation' },
  { name:'ta-lib', desc:'Technical Analysis Library. C-based, extremely fast. 150+ indicators used by professionals.', use:'ATLAS production indicators — faster than pandas-ta for live trading' },
  { name:'alpaca-trade-api', desc:'Commission-free US stock trading API. Paper trading, live trading, market data.', use:'US stock trading for ATLAS expansion, paper trading environment' },
  { name:'marketaux', desc:'Financial news API. Real-time news with sentiment scores for any stock/crypto/commodity.', use:'ATLAS news sentiment layer — trade with sentiment signals' },
],

'py-docs': [
  { name:'python-docx', desc:'Create and modify Word documents. Paragraphs, tables, images, headers, styles.', use:'Auto-generate proposals, client reports, SF-ICT ticket summaries as Word docs' },
  { name:'openpyxl', desc:'Read and write Excel files. Formatting, formulas, charts, pivot tables, images.', use:'Ad intelligence Excel export, financial reports, data delivery to non-technical clients' },
  { name:'xlsxwriter', desc:'Create Excel files with advanced formatting. Charts, conditional formatting, data validation.', use:'Professional Excel reports, formatted financial statements, color-coded outputs' },
  { name:'pdfplumber', desc:'Extract text, tables, and metadata from PDFs. Handles complex layouts.', use:'Extract data from client invoices, contracts, scanned documents, PSA exports' },
  { name:'pymupdf', desc:'Fastest PDF library. Read, write, render PDFs. OCR support. 10x faster than PyPDF2.', use:'High-volume PDF processing, PDF rendering for comparison, annotation extraction' },
  { name:'reportlab', desc:'Generate PDFs programmatically. Full control over layout, fonts, graphics, tables.', use:'Generate beautiful PDF proposals, invoices, client reports from Python' },
  { name:'python-pptx', desc:'Create and modify PowerPoint presentations. Slides, shapes, charts, images, themes.', use:'Auto-generate slide decks, client presentations, SAGE weekly report slides' },
  { name:'pillow', desc:'Python Imaging Library. Open, manipulate, save images. Resize, crop, filter, draw.', use:'Image processing for ads, thumbnail generation, screenshot processing' },
  { name:'pytesseract', desc:'OCR — extract text from images. Powered by Google Tesseract. 100+ languages.', use:'Extract text from screenshots, process scanned tickets, read image-based invoices' },
  { name:'easyocr', desc:'Ready-to-use OCR. Better accuracy than Tesseract. 80+ languages. GPU accelerated.', use:'High-accuracy text extraction from complex images and documents' },
],

'py-util': [
  { name:'tqdm', desc:'Instant progress bars for Python loops. Essential for long-running scripts.', use:'Every data processing script, scraping progress, model training feedback' },
  { name:'schedule', desc:'Job scheduling for humans. Run functions at intervals with cron-like syntax.', use:'Daily scrapers, hourly data refresh, weekly reports — simple in-process scheduling' },
  { name:'watchdog', desc:'Monitor filesystem events. React when files change, are created, or deleted.', use:'Auto-reload configs, watch for new data files, hot-reload development tools' },
  { name:'psutil', desc:'Cross-platform system and process utilities. CPU, memory, disk, network monitoring.', use:'Monitor server health in SAGE, resource usage alerts, system diagnostics' },
  { name:'paramiko', desc:'Python SSH2 protocol library. Connect to remote servers, execute commands, SFTP.', use:'Remote server management, automated deployments, data collection from remote systems' },
  { name:'cryptography', desc:'Cryptographic primitives. AES encryption, RSA, TLS, certificates, password hashing.', use:'Encrypt sensitive data at rest, API key protection, secure credential storage' },
  { name:'pycountry', desc:'ISO country, language, currency, language data. Convert between codes and names.', use:'Process geo data from Meta Ads, validate client country data, multi-language systems' },
  { name:'phonenumbers', desc:'Parse, format, validate international phone numbers (Google libphonenumber).', use:'Client contact data validation, CRM cleanup, international number formatting' },
  { name:'validators', desc:'Simple data validation. URLs, emails, IP addresses, UUIDs, cards — one function each.', use:'Input validation in APIs, data cleaning, form validation backend' },
  { name:'humanize', desc:'Turn numbers and dates into human-readable strings. "3 days ago", "1.2 million".', use:'Dashboard display text, notification messages, report summaries' },
  { name:'arrow', desc:'Better dates for Python. Timezone-aware, human-friendly, inspired by moment.js.', use:'Timezone handling for Dutch/Swiss operations, clean date formatting' },
  { name:'faker', desc:'Generate fake data. Names, addresses, emails, companies, phone numbers, credit cards.', use:'Test data generation, demo data for presentations, development without real data' },
  { name:'black', desc:'The uncompromising Python code formatter. Auto-format all Python code to one style.', use:'Keep all Python code consistently formatted. Run before every commit.' },
  { name:'pytest', desc:'The standard Python testing framework. Fixtures, parameterize, plugins, coverage.', use:'Test all Python code. Unit tests, integration tests, API tests.' },
  { name:'typer', desc:'Build CLI applications with Python type hints. Automatic --help, argument parsing.', use:'Build CLI tools for SAGE administration, MIRROR automation scripts' },
  { name:'pyfiglet', desc:'ASCII art text. Print large stylized text in the terminal.', use:'Script banners, terminal dashboards, visually identify script outputs' },
  { name:'qrcode', desc:'Generate QR codes as PNG or SVG from any data string.', use:'Share links, mobile handoff, product QR codes, contact card generation' },
],

};

// ═══════════════════════════════════════════════════════
//  CATEGORY COLORS
// ═══════════════════════════════════════════════════════
const CAT_COLORS = {
  animation:'#1BA2D2', charts:'#E4067D', '3d':'#766A86',
  ui:'#0477AE', maps:'#0a7040', media:'#b45000',
  utility:'#232430', realtime:'#b52a1c',
  'py-ai':'#7c3aed', 'py-data':'#1BA2D2', 'py-web':'#E4067D',
  'py-backend':'#0477AE', 'py-finance':'#0a7040',
  'py-docs':'#b45000', 'py-util':'#766A86',
};

// ═══════════════════════════════════════════════════════
//  RENDER ENGINE
// ═══════════════════════════════════════════════════════

let currentSection = 'animation';

function showSection(sec, el) {
  currentSection = sec;
  document.querySelectorAll('.s-item').forEach(i => i.classList.remove('active'));
  if(el) el.classList.add('active');
  if(sec === 'install') { renderInstall(); return; }
  if(JS_LIBS[sec]) renderJS(sec);
  else if(PY_PKGS[sec]) renderPY(sec);
}

function renderJS(sec) {
  const libs = JS_LIBS[sec];
  const color = CAT_COLORS[sec] || '#1BA2D2';
  const content = document.getElementById('content');
  content.innerHTML = `
    <div class="sec-hdr">
      <div class="sec-hdr-title">${sec.charAt(0).toUpperCase()+sec.slice(1).replace(/([A-Z])/g,' $1')} Libraries</div>
      <span class="sec-hdr-count">${libs.length} libraries</span>
    </div>
    <div class="lib-grid">
      ${libs.map((l,i) => `
        <div class="lib-card" style="animation:up .25s ${i*.025}s both">
          <button class="copy-btn" onclick="copyText(\`<script src=&quot;${l.cdn}&quot;></scr\`+\`ipt>\`, '${l.name}')">Copy CDN</button>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px">
            <div class="lib-name">${l.name}</div>
          </div>
          <div>${(l.tags||[]).map(t=>`<span class="tag" style="background:${color}18;color:${color}">${t}</span>`).join('')}</div>
          <div class="lib-desc">${l.desc}</div>
          <div class="lib-use"><strong style="color:${color}">Use for:</strong> ${l.use}</div>
          <div class="lib-cdn" onclick="copyText('${l.cdn}', '${l.name} CDN')">${l.cdn}</div>
        </div>
      `).join('')}
    </div>
  `;
}

function renderPY(sec) {
  const pkgs = PY_PKGS[sec];
  const color = CAT_COLORS[sec] || '#7c3aed';
  const content = document.getElementById('content');
  content.innerHTML = `
    <div class="sec-hdr">
      <div class="sec-hdr-title">${sec.replace('py-','').charAt(0).toUpperCase()+sec.replace('py-','').slice(1)} Python Packages</div>
      <span class="sec-hdr-count">${pkgs.length} packages</span>
    </div>
    <div style="background:#0f0f1a;border-radius:8px;padding:14px;font-family:'JetBrains Mono',monospace;font-size:11px;margin-bottom:16px;display:flex;align-items:center;gap:10px">
      <span style="color:rgba(255,255,255,.3)">pip install</span>
      <span style="color:${color}">${pkgs.map(p=>p.name).join(' ')}</span>
      <button onclick="copyText('pip install ${pkgs.map(p=>p.name).join(' ')}', 'pip install command')" style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:9px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);padding:4px 10px;border-radius:4px;cursor:pointer">Copy pip install</button>
    </div>
    <div class="py-grid">
      ${pkgs.map((p,i) => `
        <div class="py-pkg" onclick="copyText('pip install ${p.name}', '${p.name}')" style="animation:up .2s ${i*.02}s both">
          <div class="py-pkg-name">${p.name}</div>
          <div class="py-pkg-desc">${p.desc}</div>
          <div class="py-install" style="color:${color}">→ ${p.use.substring(0,60)}${p.use.length>60?'...':''}</div>
        </div>
      `).join('')}
    </div>
  `;
}

function renderInstall() {
  const allPy = Object.values(PY_PKGS).flat().map(p=>p.name);
  const allJs = Object.values(JS_LIBS).flat().map(l=>`<!-- ${l.name} -->\n<script src="${l.cdn}"><\/script>`);
  document.getElementById('content').innerHTML = `
    <div class="sec-hdr"><div class="sec-hdr-title">Full Install Scripts</div></div>
    <div style="margin-bottom:16px">
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between">
        Python — all ${allPy.length} packages
        <button onclick="copyText('pip install ${allPy.join(' ')}', 'All Python packages')" style="font-family:'JetBrains Mono',monospace;font-size:10px;background:var(--ink);color:white;border:none;padding:6px 14px;border-radius:5px;cursor:pointer">Copy pip install all</button>
      </div>
      <div class="pip-block">pip install ${allPy.join(' \\\n  ')}</div>
    </div>
    <div>
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:8px">Node — global packages</div>
      <div class="pip-block">npm install -g vercel netlify-cli serve http-server nodemon pm2 typescript ts-node vite @anthropic-ai/sdk prettier eslint concurrently dotenv-cli json-server localtunnel</div>
    </div>
  `;
}

function copyText(text, label) {
  navigator.clipboard.writeText(text).then(() => {
    const t = document.getElementById('toast');
    t.textContent = (label||'') + ' copied ✓';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2000);
  });
}

function copyAllPip() {
  const all = Object.values(PY_PKGS).flat().map(p=>p.name).join(' ');
  copyText('pip install ' + all, 'All pip packages');
}

function searchLibs(q) {
  if(!q) { showSection(currentSection, null); return; }
  const term = q.toLowerCase();
  const jsResults = Object.entries(JS_LIBS).flatMap(([cat, libs]) =>
    libs.filter(l => l.name.toLowerCase().includes(term) || l.desc.toLowerCase().includes(term) || l.use.toLowerCase().includes(term))
      .map(l => ({...l, _cat:cat, _type:'js'}))
  );
  const pyResults = Object.entries(PY_PKGS).flatMap(([cat, pkgs]) =>
    pkgs.filter(p => p.name.toLowerCase().includes(term) || p.desc.toLowerCase().includes(term))
      .map(p => ({...p, _cat:cat, _type:'py'}))
  );
  const color = '#1BA2D2';
  document.getElementById('content').innerHTML = `
    <div class="sec-hdr">
      <div class="sec-hdr-title">Search: "${q}"</div>
      <span class="sec-hdr-count">${jsResults.length + pyResults.length} results</span>
    </div>
    ${jsResults.length ? `
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--purple);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">JS Libraries (${jsResults.length})</div>
      <div class="lib-grid" style="margin-bottom:24px">
        ${jsResults.map(l=>`
          <div class="lib-card">
            <button class="copy-btn" onclick="copyText('${l.cdn}', '${l.name}')">Copy CDN</button>
            <div class="lib-name">${l.name}</div>
            <div class="lib-desc">${l.desc}</div>
            <div class="lib-use"><strong style="color:${color}">Use:</strong> ${l.use}</div>
            <div class="lib-cdn">${l.cdn}</div>
          </div>`).join('')}
      </div>` : ''}
    ${pyResults.length ? `
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--purple);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">Python Packages (${pyResults.length})</div>
      <div class="py-grid">
        ${pyResults.map(p=>`
          <div class="py-pkg" onclick="copyText('pip install ${p.name}', '${p.name}')">
            <div class="py-pkg-name">${p.name}</div>
            <div class="py-pkg-desc">${p.desc}</div>
          </div>`).join('')}
      </div>` : ''}
    ${!jsResults.length && !pyResults.length ? '<div style="text-align:center;padding:48px;color:var(--purple)">No results found</div>' : ''}
  `;
}

// Update sidebar counts
function updateCounts() {
  let total = 0;
  Object.entries(JS_LIBS).forEach(([k,v]) => {
    const el = document.getElementById('sc-'+k);
    if(el) el.textContent = v.length;
    total += v.length;
  });
  Object.entries(PY_PKGS).forEach(([k,v]) => {
    const el = document.getElementById('sc-'+k);
    if(el) el.textContent = v.length;
    total += v.length;
  });
  document.getElementById('total-count').textContent = total;
}

// CSS anim
const s = document.createElement('style');
s.textContent = '@keyframes up{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}';
document.head.appendChild(s);

// INIT
updateCounts();
showSection('animation', document.querySelector('.s-item'));
</script>
</body>
</html>
