<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Polypus Master Dev Kit</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@300;400;500&family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
<script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/CountUp.js/2.8.0/countUp.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dayjs@1.11.10/dayjs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<style>
:root {
  --ink:#232430; --blue:#1BA2D2; --blue-dark:#0477AE;
  --pink:#E4067D; --purple:#766A86; --bg:#EAF2FB;
  --surface:#dbeaf6; --border:#c8dff0; --white:#fff;
  --green:#0a7040; --amber:#b45000; --red:#b52a1c;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Instrument Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh}
.mono{font-family:'JetBrains Mono',monospace}
.syne{font-family:'Syne',sans-serif}

/* HEADER */
.hdr{background:var(--ink);position:sticky;top:0;z-index:1000;padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(27,162,210,.2)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;background:linear-gradient(135deg,#1BA2D2,#E4067D);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* SIDEBAR */
.layout{display:flex;min-height:calc(100vh - 56px)}
.sidebar{width:220px;background:var(--ink);flex-shrink:0;position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;padding:16px 0}
.sidebar::-webkit-scrollbar{width:3px}
.sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px}
.s-section{padding:10px 16px 4px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.25)}
.s-item{display:flex;align-items:center;gap:8px;padding:7px 16px;cursor:pointer;color:rgba(255,255,255,.5);font-size:12px;transition:all .15s;border-left:2px solid transparent}
.s-item:hover{color:white;background:rgba(255,255,255,.04)}
.s-item.active{color:#1BA2D2;border-left-color:#1BA2D2;background:rgba(27,162,210,.07)}
.s-count{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;background:rgba(255,255,255,.08);padding:1px 6px;border-radius:8px;color:rgba(255,255,255,.4)}

/* MAIN */
.main{flex:1;padding:28px 32px;overflow-x:hidden}

/* SEARCH */
.search-bar{display:flex;gap:10px;margin-bottom:24px}
.search-input{flex:1;font-family:'JetBrains Mono',monospace;font-size:12px;background:var(--white);border:1px solid var(--border);border-radius:8px;padding:10px 16px;outline:none;transition:border .15s}
.search-input:focus{border-color:var(--blue)}
.search-input::placeholder{color:var(--purple)}

/* STATS BAR */
.stats-bar{display:grid;grid-template-columns:repeat(8,1fr);gap:10px;margin-bottom:24px}
.stat-pill{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:10px 12px;text-align:center;cursor:pointer;transition:all .15s}
.stat-pill:hover,.stat-pill.active{border-color:var(--blue);background:var(--blue-lt, #d6f0f9)}
.stat-n{font-family:'Syne',sans-serif;font-weight:800;font-size:20px}
.stat-l{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--purple);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* GRID */
.lib-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}
.lib-card{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:16px;position:relative;transition:all .2s;cursor:default}
.lib-card:hover{border-color:var(--blue);box-shadow:0 2px 12px rgba(27,162,210,.12);transform:translateY(-1px)}
.lib-name{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:3px}
.lib-desc{font-size:11px;color:var(--purple);line-height:1.5;margin-bottom:8px}
.lib-use{font-size:11px;color:var(--ink);margin-bottom:8px;line-height:1.4}
.lib-cdn{font-family:'JetBrains Mono',monospace;font-size:9px;background:#0f0f1a;color:#88c0d0;padding:7px 10px;border-radius:5px;cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:background .15s}
.lib-cdn:hover{background:#1a1a2e}
.tag{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:9px;padding:2px 7px;border-radius:3px;font-weight:600;letter-spacing:.04em;margin-right:4px;margin-bottom:6px}
.copy-btn{position:absolute;top:10px;right:10px;font-family:'JetBrains Mono',monospace;font-size:9px;background:var(--surface);border:1px solid var(--border);color:var(--purple);padding:3px 8px;border-radius:4px;cursor:pointer;transition:all .15s}
.copy-btn:hover{background:var(--blue);color:white;border-color:var(--blue)}

/* PYTHON SECTION */
.py-section{margin-bottom:32px}
.py-title{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.py-sub{font-size:12px;color:var(--purple);margin-bottom:12px}
.py-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px}
.py-pkg{background:var(--white);border:1px solid var(--border);border-radius:7px;padding:11px 13px;display:flex;flex-direction:column;gap:3px;cursor:pointer;transition:all .15s}
.py-pkg:hover{border-color:var(--blue);background:#f0f8fd}
.py-pkg-name{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:500;color:var(--ink)}
.py-pkg-desc{font-size:11px;color:var(--purple);line-height:1.4}
.py-install{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--blue-dark)}

/* TOAST */
.toast{position:fixed;bottom:20px;right:20px;background:var(--ink);color:white;font-family:'JetBrains Mono',monospace;font-size:11px;padding:9px 16px;border-radius:7px;z-index:9999;opacity:0;transform:translateY(6px);transition:all .2s;pointer-events:none;border-left:3px solid var(--blue)}
.toast.show{opacity:1;transform:translateY(0)}

/* PIP SCRIPT */
.pip-block{background:#0f0f1a;border-radius:10px;padding:20px;font-family:'JetBrains Mono',monospace;font-size:11px;color:#88c0d0;line-height:1.8;position:relative;overflow-x:auto;margin-bottom:24px}
.pip-comment{color:rgba(255,255,255,.25)}
.pip-cmd{color:#E4067D}
.pip-pkg{color:#1BA2D2}

/* SECTION HEADER */
.sec-hdr{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.sec-hdr-title{font-family:'Syne',sans-serif;font-weight:700;font-size:20px}
.sec-hdr-count{font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--surface);border:1px solid var(--border);padding:3px 10px;border-radius:20px;color:var(--purple)}
</style>
</head>
<body>

<!-- HEADER -->
<div class="hdr">
  <div class="logo">Polypus Master Dev Kit</div>
  <div style="display:flex;align-items:center;gap:20px">
    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(255,255,255,.35)">
      <span id="total-count" style="color:#1BA2D2;font-size:14px;font-weight:700">0</span> libraries &amp; packages
    </div>
    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(255,255,255,.35)">
      <span style="color:#E4067D;font-size:14px;font-weight:700">12</span> categories
    </div>
  </div>
</div>

<div class="layout">

<!-- SIDEBAR -->
<nav class="sidebar" id="sidebar">
  <div class="s-section">Frontend JS</div>
  <div class="s-item active" onclick="showSection('animation',this)">🎬 Animation<span class="s-count" id="sc-animation">0</span></div>
  <div class="s-item" onclick="showSection('charts',this)">📊 Charts & Dataviz<span class="s-count" id="sc-charts">0</span></div>
  <div class="s-item" onclick="showSection('3d',this)">🧊 3D & Canvas<span class="s-count" id="sc-3d">0</span></div>
  <div class="s-item" onclick="showSection('ui',this)">🎨 UI Components<span class="s-count" id="sc-ui">0</span></div>
  <div class="s-item" onclick="showSection('maps',this)">🗺 Maps & Geo<span class="s-count" id="sc-maps">0</span></div>
  <div class="s-item" onclick="showSection('media',this)">🎵 Audio & Video<span class="s-count" id="sc-media">0</span></div>
  <div class="s-item" onclick="showSection('utility',this)">🔧 Utilities<span class="s-count" id="sc-utility">0</span></div>
  <div class="s-item" onclick="showSection('realtime',this)">⚡ Realtime<span class="s-count" id="sc-realtime">0</span></div>
  <div class="s-section">Python</div>
  <div class="s-item" onclick="showSection('py-ai',this)">🤖 AI & LLM<span class="s-count" id="sc-py-ai">0</span></div>
  <div class="s-item" onclick="showSection('py-data',this)">📈 Data & ML<span class="s-count" id="sc-py-data">0</span></div>
  <div class="s-item" onclick="showSection('py-web',this)">🕷 Scraping & Web<span class="s-count" id="sc-py-web">0</span></div>
  <div class="s-item" onclick="showSection('py-backend',this)">⚙️ Backend & APIs<span class="s-count" id="sc-py-backend">0</span></div>
  <div class="s-item" onclick="showSection('py-finance',this)">💹 Finance & Trading<span class="s-count" id="sc-py-finance">0</span></div>
  <div class="s-item" onclick="showSection('py-docs',this)">📄 Documents<span class="s-count" id="sc-py-docs">0</span></div>
  <div class="s-item" onclick="showSection('py-util',this)">🛠 Python Utils<span class="s-count" id="sc-py-util">0</span></div>
  <div class="s-section">Install Scripts</div>
  <div class="s-item" onclick="showSection('install',this)">📦 Full pip install</div>
  <div class="s-item" onclick="showSection('install',this)">📦 Node globals</div>
</nav>

<!-- MAIN -->
<main class="main">

  <!-- SEARCH -->
  <div class="search-bar">
    <input class="search-input" id="search" placeholder="Search any library or package... (e.g. 'chart', 'scrape', 'animation')" oninput="searchLibs(this.value)">
    <button onclick="copyAllPip()" style="font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--ink);color:white;border:none;padding:10px 18px;border-radius:8px;cursor:pointer;white-space:nowrap">Copy pip install all</button>
  </div>

  <!-- CONTENT AREA -->
  <div id="content"></div>

</main>
</div>

<div class="toast" id="toast">Copied!</div>

<script>
// ═══════════════════════════════════════════════════════
//  MASTER LIBRARY DATABASE
// ═══════════════════════════════════════════════════════

const JS_LIBS = {

animation: [
  { name:'GSAP', desc:'The gold standard for web animation. Timelines, scroll triggers, morphing, text effects. Used by Apple, Google, NASA.', use:'Slide transitions, number reveals, hero animations, scroll-driven UIs', cdn:'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/gsap.min.js', tags:['Animation','Pro'] },
  { name:'GSAP ScrollTrigger', desc:'GSAP plugin. Trigger any animation based on scroll position. Scrub, pin, snap.', use:'Scroll-based storytelling, parallax dashboards, on-scroll reveals', cdn:'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/ScrollTrigger.min.js', tags:['Animation','Scroll'] },
  { name:'GSAP TextPlugin', desc:'GSAP plugin. Type text character by character with full easing control.', use:'AI typing effect, terminal output simulation, live feed text', cdn:'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.3/TextPlugin.min.js', tags:['Animation','Text'] },
  { name:'Anime.js', desc:'Lightweight alternative to GSAP. CSS, SVG, DOM and JS object animations. Great for simple UI motion.', use:'Icon bounce effects, loading states, card entrances', cdn:'https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js', tags:['Animation'] },
  { name:'Lottie Web', desc:'Render After Effects animations exported as JSON. 500k+ free animations on LottieFiles.', use:'Loading spinners, success checkmarks, empty states, onboarding illustrations', cdn:'https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js', tags:['Animation','Design'] },
  { name:'Typed.js', desc:'Typewriter effect library. Types and deletes strings with configurable speed and cursor.', use:'Hero section headlines, AI response simulation, terminal demos', cdn:'https://cdnjs.cloudflare.com/ajax/libs/typed.js/2.0.16/typed.umd.js', tags:['Animation','Text'] },
  { name:'AOS', desc:'Animate On Scroll. Add data-aos attributes to any element for scroll-triggered entrance animations.', use:'Landing page sections, feature reveals, statistics counters on scroll', cdn:'https://unpkg.com/aos@2.3.1/dist/aos.js', tags:['Animation','Scroll'] },
  { name:'Rellax', desc:'Buttery smooth parallax scrolling. Any element scrolls at a different speed creating depth.', use:'Hero backgrounds, decorative elements, pitch deck depth effects', cdn:'https://cdnjs.cloudflare.com/ajax/libs/rellax/1.12.1/rellax.min.js', tags:['Animation','Scroll'] },
  { name:'CountUp.js', desc:'Animated number counters. Smooth count from 0 to any number with easing, decimals, prefix, suffix.', use:'Dashboard KPI reveals, stats sections, ROAS counters, live metrics', cdn:'https://cdnjs.cloudflare.com/ajax/libs/CountUp.js/2.8.0/countUp.umd.js', tags:['Animation','Numbers'] },
  { name:'Velocity.js', desc:'Fast DOM animation engine. jQuery-compatible API but much faster. Hardware accelerated.', use:'Complex multi-step UI animations, legacy project upgrades', cdn:'https://cdnjs.cloudflare.com/ajax/libs/velocity/2.0.6/velocity.min.js', tags:['Animation'] },
  { name:'Motion One', desc:'Modern animation library built on the Web Animations API. Tiny and incredibly fast.', use:'Micro-interactions, gesture-driven UI, React/Vue animations', cdn:'https://cdn.jsdelivr.net/npm/motion@10.16.4/dist/motion.js', tags:['Animation','Modern'] },
  { name:'Popmotion', desc:'Functional animation library. Spring physics, decay, keyframe animations. Powers Framer Motion.', use:'Physics-based UI, chat bubble springs, drag interactions', cdn:'https://unpkg.com/popmotion/dist/popmotion.global.min.js', tags:['Animation','Physics'] },
],

charts: [
  { name:'Chart.js', desc:'The most popular charting library. 8 chart types, all animated, easy API. Perfect for standard dashboards.', use:'Bar charts, line charts, doughnut charts in all dashboards', cdn:'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js', tags:['Charts','Simple'] },
  { name:'ApexCharts', desc:'Advanced charts with real-time updates, zoom, pan, candlestick, heatmap, treemap. Better than Chart.js for complex data.', use:'ATLAS trading charts, MIRROR AB testing, SAGE ticket heatmaps', cdn:'https://cdn.jsdelivr.net/npm/apexcharts', tags:['Charts','Advanced','Realtime'] },
  { name:'D3.js', desc:'The most powerful data visualization library ever built. Unlimited custom visualizations using SVG and Canvas.', use:'Network graphs, force-directed layouts, geographic choropleth, custom viz', cdn:'https://d3js.org/d3.v7.min.js', tags:['Charts','Custom','Advanced'] },
  { name:'ECharts', desc:'Apache ECharts. Extremely powerful, handles millions of data points. Better performance than D3 for large datasets.', use:'Fleet monitoring dashboards, real-time telemetry, 3D bar charts', cdn:'https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js', tags:['Charts','Performance','3D'] },
  { name:'Plotly.js', desc:'Interactive scientific charts. Box plots, violin, contour, 3D scatter, geo maps. Used by data scientists.', use:'ATLAS strategy analysis, ML model outputs, statistical reporting', cdn:'https://cdn.plot.ly/plotly-2.26.0.min.js', tags:['Charts','Scientific','3D'] },
  { name:'Frappe Charts', desc:'GitHub-style charts. Beautiful heatmaps, percentage bars, line and bar. Zero config, just data in.', use:'Ticket frequency calendars, commit-style activity grids, sprint burndown', cdn:'https://cdn.jsdelivr.net/npm/frappe-charts@1.6.2/dist/frappe-charts.min.umd.js', tags:['Charts','Simple'] },
  { name:'uPlot', desc:'Insanely fast lightweight chart library. Renders 100k+ data points smoothly. For live time-series.', use:'ATLAS real-time price charts, endpoint telemetry streams, log graphs', cdn:'https://cdn.jsdelivr.net/npm/uplot@1.6.31/dist/uPlot.iife.min.js', tags:['Charts','Performance','Realtime'] },
  { name:'ProgressBar.js', desc:'Animated SVG progress bars and circles. Fully configurable colors, stroke, easing, text.', use:'Endpoint health rings, campaign budget gauges, sprint progress circles', cdn:'https://cdn.jsdelivr.net/npm/progressbar.js@1.1.0/dist/progressbar.min.js', tags:['Charts','UI'] },
  { name:'Gauge.js', desc:'Beautiful animated gauge charts. Like a speedometer. Perfect for single KPI display.', use:'ROAS gauge, FCR rate, endpoint health score, ATLAS win rate', cdn:'https://cdn.jsdelivr.net/npm/gauge.js@1.3.7/dist/gauge.min.js', tags:['Charts','KPI'] },
  { name:'wordcloud2.js', desc:'Generates word clouds in Canvas. Size words by frequency. Beautiful for text analysis.', use:'Ticket keyword clouds, competitor ad copy analysis, client request themes', cdn:'https://cdn.jsdelivr.net/npm/wordcloud@1.2.2/src/wordcloud2.js', tags:['Charts','Text'] },
  { name:'Billboard.js', desc:'D3-based chart library with simpler API. NVD3 successor. Great middle ground between Chart.js and D3.', use:'Complex multi-series line charts, combination charts, grouped bars', cdn:'https://cdn.jsdelivr.net/npm/billboard.js/dist/billboard.min.js', tags:['Charts'] },
],

'3d': [
  { name:'Three.js', desc:'The standard WebGL library. Build full 3D scenes, models, lighting, cameras, shaders. Massive ecosystem.', use:'Agent office 3D environment, 3D data globe, hero background scenes', cdn:'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js', tags:['3D','WebGL'] },
  { name:'Babylon.js', desc:'Full 3D game engine in the browser. Physics, collisions, shadows, VR/AR support. More complete than Three.js.', use:'Interactive product demos, 3D client environment maps, immersive dashboards', cdn:'https://cdn.babylonjs.com/babylon.js', tags:['3D','WebGL','Engine'] },
  { name:'PixiJS', desc:'2D WebGL renderer. Insanely fast 2D sprites, particles, filters. Best for 2D canvas performance.', use:'Real-time data visualizations, animated dashboards, particle systems', cdn:'https://cdn.jsdelivr.net/npm/pixi.js@7.3.2/dist/pixi.min.js', tags:['2D','WebGL','Performance'] },
  { name:'Fabric.js', desc:'HTML5 Canvas made easy. Draw, drag, scale, rotate objects. Full canvas interactivity.', use:'Image editor, whiteboard tools, ad creative builder, diagram editor', cdn:'https://cdn.jsdelivr.net/npm/fabric@5.3.0/dist/fabric.min.js', tags:['Canvas','2D'] },
  { name:'Konva.js', desc:'2D Canvas framework for desktop and mobile. Layers, events, drag and drop, animations.', use:'Interactive network diagrams, floor plans, node-based editors', cdn:'https://unpkg.com/konva@9/konva.min.js', tags:['Canvas','2D','Interactive'] },
  { name:'Rough.js', desc:'Creates graphics that look hand-drawn. Sketchy aesthetic for any shape or path.', use:'Wireframe-style prototypes, playful dashboards, design assets', cdn:'https://unpkg.com/roughjs@4.6.6/bundled/rough.js', tags:['Canvas','Design'] },
  { name:'Zdog', desc:'Flat, round, designer-friendly pseudo-3D engine. Beautiful 3D illustrations with minimal code.', use:'Logo animations, icon 3D effects, decorative UI elements', cdn:'https://unpkg.com/zdog@1/zdog.dist.min.js', tags:['3D','Design'] },
  { name:'Particles.js', desc:'Configurable particle and network backgrounds. Connect dots, repel on hover, custom shapes.', use:'Hero sections, cover slides, loading screens, ambient UI backgrounds', cdn:'https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js', tags:['3D','Background'] },
  { name:'tsParticles', desc:'Evolved particles.js. More shapes, connections, polygon masks, fireworks, confetti, snow.', use:'Celebration animations, dynamic backgrounds, interactive hero sections', cdn:'https://cdn.jsdelivr.net/npm/tsparticles@2.12.0/tsparticles.bundle.min.js', tags:['3D','Background','Interactive'] },
  { name:'Matter.js', desc:'2D physics engine. Rigid bodies, collision detection, gravity, constraints, composites.', use:'Interactive UI physics, bouncing elements, game mechanics', cdn:'https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js', tags:['Physics','2D'] },
],

ui: [
  { name:'Tailwind CSS', desc:'Utility-first CSS. Build any design without leaving HTML. 10x faster than custom CSS. Must-have.', use:'Every single project. Replaces custom CSS almost entirely.', cdn:'https://cdn.tailwindcss.com', tags:['CSS','Framework','Essential'] },
  { name:'Alpine.js', desc:'Lightweight reactivity in HTML attributes. No build step. Replaces jQuery for simple interactivity.', use:'Dropdowns, tabs, modals, toggles, state management without React', cdn:'https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js', tags:['JS','Reactivity'] },
  { name:'Lucide Icons', desc:'1,400+ consistent, clean SVG icons. Each icon is identical stroke width and style.', use:'Replace all emoji in dashboards. Navigation, status, actions, categories.', cdn:'https://unpkg.com/lucide@latest/dist/umd/lucide.js', tags:['Icons','Essential'] },
  { name:'Heroicons', desc:'Beautiful hand-crafted SVG icons by Tailwind team. Outline and solid variants.', use:'Tailwind-native icon set for all Tailwind projects', cdn:'https://unpkg.com/heroicons@2.0.18/24/outline/index.js', tags:['Icons'] },
  { name:'Phosphor Icons', desc:'Flexible icon family. 6 weights per icon — thin, light, regular, bold, fill, duotone. 1,200+ icons.', use:'Rich UI with multiple icon weights, design-heavy interfaces', cdn:'https://unpkg.com/@phosphor-icons/web', tags:['Icons','Design'] },
  { name:'Tippy.js', desc:'Complete tooltip and popover solution. Hover, click, focus triggers. Animated, themeable, custom HTML.', use:'Help tooltips on every dashboard, data previews, context menus', cdn:'https://unpkg.com/tippy.js@6', tags:['UI','Tooltip'] },
  { name:'SweetAlert2', desc:'Beautiful replacement for browser alerts. Modals with custom buttons, inputs, timers, icons.', use:'Confirmation dialogs, delete confirmations, success messages, input prompts', cdn:'https://cdn.jsdelivr.net/npm/sweetalert2@11', tags:['UI','Modal'] },
